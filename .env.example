# Supabase — get these from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cron authorization
# CRON_SECRET=

# Resend email alerts
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=HOMEBOT <alerts@yourdomain.com>

# Anthropic API (for consumable suggestions + warranty estimates)
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# Product lookup uses ENERGY STAR open data (free, no API key needed)
# Brand/model dropdowns are powered by data.energystar.gov SODA API
# Product enrichment uses Bing Image Search (free, no API key needed)

# Google OAuth2 (Gmail utility bill scanning)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Gmail token encryption key (generate with: openssl rand -hex 32)
# GMAIL_TOKEN_ENCRYPTION_KEY=

# Optional: Twilio SMS alerts
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
